{
  "name": "SnapDraft",
  "description": "From thought to sent in seconds. SnapDraft's AI generates professional emails on demand.",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:8080/*", "*://mail.google.com/*"],
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["*://mail.google.com/*"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["SnapDraft.png"],
      "matches": ["*://mail.google.com/*"]
    }
  ],
  "action": {
    "default_icon": {
      "16": "SnapDraft.png",
      "48": "SnapDraft.png",
      "128": "SnapDraft.png"
    }
  }
}
